---
import "../assets/app.css";

interface Props {
	title?: string;
}

const { title = "Domovi za starejše - Stanje kapacitet" } = Astro.props;
---

<!doctype html>
<html lang="sl" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Pregled zasedenosti domov za starejše v Sloveniji" />
		<title>{title}</title>
		<script defer src="https://analytics.mapsoft.net/script.js" data-website-id="7b94233a-1086-4052-b6c7-da93b30d475e"></script>
	</head>
	<body class="min-h-screen bg-white antialiased">
		<slot />
	</body>
</html>
