---
import Layout from "../layouts/Layout.astro";
import Chart from "../components/Chart.astro";

const dataFiles = import.meta.glob("../data/*.json", { eager: true });
const sortedFiles = Object.entries(dataFiles)
  .filter(([path]) => /\/\d{4}-\d{2}-\d{2}\.json$/.test(path))
  .sort(([a], [b]) => b.localeCompare(a));

if (sortedFiles.length === 0) {
  throw new Error("No data files found");
}

const [, latestModule] = sortedFiles[0];
const data = latestModule as any;

const { grandTotals, reportDate, regions } = data.data;
const { allApplications, allApplicants } = grandTotals;

let freeSpotsChange: number | null = null;
let activeApplicationsChange: number | null = null;
let activeApplicantsChange: number | null = null;

if (sortedFiles.length >= 2) {
  const prevData = (sortedFiles[1][1] as any).data;
  const prevApplications = prevData.grandTotals.allApplications;
  const prevApplicants = prevData.grandTotals.allApplicants;

  freeSpotsChange = allApplications.freeSpots - prevApplications.freeSpots;
  activeApplicationsChange = allApplications.active - prevApplications.active;
  activeApplicantsChange = allApplicants.active - prevApplicants.active;
}

const formatChange = (change: number | null) => {
  if (change === null) return null;
  const sign = change > 0 ? "+" : "";
  return `${sign}${change.toLocaleString("sl-SI")}`;
};

const occupied = allApplications.capacity - allApplications.freeSpots;
const occupancyPercent = ((occupied / allApplications.capacity) * 100).toFixed(
  2,
);
const occupancyWidth = `${Math.min(100, Number(occupancyPercent)).toFixed(2)}%`;
const freeWidth = `${Math.max(0, 100 - Number(occupancyPercent)).toFixed(2)}%`;
const applicantsPerSpot =
  allApplications.freeSpots > 0
    ? Math.round(allApplicants.active / allApplications.freeSpots)
    : allApplicants.active;
const totalFacilities = regions.reduce(
  (acc, r) => acc + r.facilities.length,
  0,
);
const avgApplicationsPerFacility = Math.round(
  allApplications.active / totalFacilities,
);

const formatNumber = (num: number) => num.toLocaleString("sl-SI");

const facilitiesWithSpots = regions.flatMap((r) =>
  r.facilities
    .filter((f) => f.freeSpots && f.freeSpots > 0)
    .map((f) => ({ ...f, region: r.name })),
);

const pricingFiles = import.meta.glob("../data/pricing/*.json", {
  eager: true,
});
const pricingData = Object.values(pricingFiles) as any[];

pricingData.forEach((facility: any) => {
  facility.room_pricing.sort(
    (a: any, b: any) => a.monthly_rate - b.monthly_rate,
  );
});

const maxRooms = Math.max(
  ...pricingData.map((p: any) => p.room_pricing.length),
);

const formatCurrency = (num: number) =>
  num.toLocaleString("sl-SI", { style: "currency", currency: "EUR" });

const metricCards = [
  {
    label: "Aktivne prošnje",
    value: formatNumber(allApplications.active),
    note: `${formatNumber(allApplications.registered)} vseh prijav`,
    change: activeApplicationsChange,
    favorableWhenPositive: false,
  },
  {
    label: "Aktivni prosilci",
    value: formatNumber(allApplicants.active),
    note: `${formatNumber(allApplicants.registered)} vseh prosilcev`,
    change: activeApplicantsChange,
    favorableWhenPositive: false,
  },
];
---

<Layout title="Domovi za starejše - Pregled kapacitet">
  <main class="min-h-screen bg-white text-zinc-950">
    <section class="relative isolate min-h-[720px] overflow-hidde bg-white">
      <Chart variant="hero" />
      <div
        class="pointer-events-none relative z-10 mx-auto flex min-h-[620px] max-w-7xl flex-col justify-between px-5 py-7 sm:px-8 lg:px-10 lg:py-10"
      >
        <header class="flex items-center justify-between gap-4">
          <a
            href="/"
            class="pointer-events-auto text-sm font-semibold tracking-tight text-zinc-950"
          >
            Domovi za starejše
          </a>
        </header>

        <div class="max-w-2xl">
          <div
            class="mb-5 text-sm font-medium uppercase tracking-[0.16em] text-amber-700"
          >
            Podatki: {reportDate}
          </div>
          <h1
            class="max-w-4xl text-5xl font-semibold leading-[0.96] tracking-tight text-zinc-950 sm:text-6xl lg:text-6xl"
          >
            Aktivne prošnje skozi čas.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-600">
            Pregled obremenitve domov za starejše v Sloveniji, postavljen čez
            dnevni trend aktivnih prošenj.
          </p>
        </div>

        <div class="grid max-w-3xl gap-3 pt-2 sm:grid-cols-3">
          <div>
            <p
              class="text-xs font-medium uppercase tracking-[0.14em] text-zinc-500"
            >
              Prosta mesta
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-950">
              {formatNumber(allApplications.freeSpots)}
            </p>
          </div>
          <div>
            <p
              class="text-xs font-medium uppercase tracking-[0.14em] text-zinc-500"
            >
              Zasedenost
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-950">
              {occupancyPercent}%
            </p>
          </div>
          <div>
            <p
              class="text-xs font-medium uppercase tracking-[0.14em] text-zinc-500"
            >
              Prosilci
            </p>
            <p class="mt-1 text-2xl font-semibold text-zinc-950">
              {formatNumber(allApplicants.active)}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-5 py-8 sm:px-8 lg:px-10">
      <div class="grid gap-4 md:grid-cols-2">
        {
          metricCards.map((metric, index) => {
            const isNeutral = metric.change === null || metric.change === 0;
            const isPositive =
              metric.change !== null &&
              metric.change !== 0 &&
              (metric.favorableWhenPositive
                ? metric.change > 0
                : metric.change < 0);

            return (
              <article
                class={`rounded-lg border bg-white p-5 transition hover:shadow-sm ${
                  index === 0
                    ? "border-amber-200 shadow-[inset_0_3px_0_#f59e0b]"
                    : "border-sky-200 shadow-[inset_0_3px_0_#0ea5e9]"
                }`}
              >
                <div class="flex items-start justify-between gap-4">
                  <p class="text-sm font-medium text-zinc-500">
                    {metric.label}
                  </p>
                  <span
                    class={`rounded-full px-2.5 py-1 text-xs font-medium ${
                      isNeutral
                        ? "bg-zinc-100 text-zinc-500"
                        : isPositive
                          ? "bg-emerald-50 text-emerald-700"
                          : "bg-amber-50 text-amber-700"
                    }`}
                  >
                    {isNeutral ? "brez sprememb" : formatChange(metric.change)}
                  </span>
                </div>
                <p class="mt-5 text-4xl font-semibold tracking-tight text-zinc-950">
                  {metric.value}
                </p>
                <p class="mt-2 text-sm text-zinc-500">{metric.note}</p>
              </article>
            );
          })
        }
      </div>

      <div class="mt-8">
        <section
          class="rounded-lg border border-emerald-200 bg-[linear-gradient(135deg,#ecfdf5_0%,#ffffff_62%,#eff6ff_100%)] p-6"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-medium text-emerald-700">Kapacitete</p>
              <h2
                class="mt-2 text-4xl font-semibold tracking-tight text-zinc-950"
              >
                {formatNumber(occupied)}
              </h2>
            </div>
            <span
              class="rounded-full bg-emerald-600 px-3 py-1 text-xs font-medium text-white"
            >
              {occupancyPercent}% zasedeno
            </span>
          </div>
          <div
            class="mt-8 h-4 overflow-hidden rounded-full bg-white shadow-inner ring-1 ring-emerald-100"
          >
            <div
              class="h-full rounded-full bg-gradient-to-r from-amber-400 via-orange-500 to-rose-500"
              style={`width: ${occupancyWidth}`}
            >
            </div>
          </div>
          <div class="mt-4 grid gap-3 text-sm text-zinc-700 sm:grid-cols-3">
            <p>
              <span
                class="block text-xs uppercase tracking-[0.12em] text-zinc-500"
                >Zasedeno</span
              >
              <strong class="text-base text-zinc-950"
                >{formatNumber(occupied)}</strong
              >
            </p>
            <p>
              <span
                class="block text-xs uppercase tracking-[0.12em] text-zinc-500"
                >Kapaciteta</span
              >
              <strong class="text-base text-zinc-950"
                >{formatNumber(allApplications.capacity)}</strong
              >
            </p>
            <p>
              <span
                class="block text-xs uppercase tracking-[0.12em] text-zinc-500"
                >Razpoložljivo</span
              >
              <strong class="text-base text-zinc-950">{freeWidth}</strong>
            </p>
          </div>
          <p
            class="mt-6 border-t border-emerald-100 pt-5 text-sm leading-6 text-zinc-600"
          >
            Aktivne prošnje: <strong class="font-semibold text-zinc-950"
              >{formatNumber(allApplications.active)}</strong
            >. Status prikazuje razmerje med zasedenimi kapacitetami in skupno
            zmogljivostjo.
          </p>
        </section>
      </div>
    </section>

    {
      facilitiesWithSpots.length > 0 && (
        <section class="border-y border-emerald-100 bg-emerald-50/40">
          <div class="mx-auto max-w-7xl px-5 py-10 sm:px-8 lg:px-10">
            <div class="mb-6 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.14em] text-emerald-700">
                  Razpoložljivost
                </p>
                <h2 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-950">
                  Domovi s prostimi mesti
                </h2>
              </div>
              <p class="text-sm text-zinc-500">
                {facilitiesWithSpots.length} domov ima evidentirana prosta
                mesta.
              </p>
            </div>

            <div class="overflow-hidden rounded-lg border border-zinc-200 bg-white">
              <table class="w-full min-w-[640px] text-left text-sm">
                <thead class="border-b border-zinc-200 bg-white text-xs uppercase tracking-[0.12em] text-zinc-500">
                  <tr>
                    <th class="px-4 py-3 font-medium">Dom</th>
                    <th class="px-4 py-3 font-medium">Regija</th>
                    <th class="px-4 py-3 text-right font-medium">Mesta</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100">
                  {facilitiesWithSpots.map((f) => (
                    <tr class="transition hover:bg-zinc-50">
                      <td class="px-4 py-4 font-medium text-zinc-950">
                        {f.name}
                      </td>
                      <td class="px-4 py-4 text-zinc-500">{f.region}</td>
                      <td class="px-4 py-4 text-right">
                        <span class="rounded-full bg-emerald-50 px-3 py-1 text-sm font-semibold text-emerald-700">
                          {f.freeSpots}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      )
    }

    <section class="mx-auto max-w-7xl px-5 py-10 sm:px-8 lg:px-10">
      <div
        class="mb-6 flex flex-col justify-between gap-3 sm:flex-row sm:items-end"
      >
        <div>
          <p
            class="text-sm font-medium uppercase tracking-[0.14em] text-zinc-500"
          >
            Regije
          </p>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-950">
            Zasedenost po regijah
          </h2>
        </div>
        <p class="max-w-md text-sm leading-6 text-zinc-500">
          Vsaka vrstica prikazuje regijsko zasedenost, prosta mesta in seznam
          vključenih domov.
        </p>
      </div>

      <div
        class="divide-y divide-zinc-200 rounded-lg border border-zinc-200 bg-white"
      >
        {
          regions.map((region) => {
            const regionOccupied =
              region.totals.totalApplications.capacity -
              region.totals.totalApplications.freeSpots;
            const regionPercent = (
              (regionOccupied / region.totals.totalApplications.capacity) *
              100
            ).toFixed(1);
            const hasSpots = region.totals.totalApplications.freeSpots > 0;

            return (
              <details
                class={`group ${hasSpots ? "bg-emerald-50/55" : "bg-white"}`}
              >
                <summary
                  class={`grid cursor-pointer list-none gap-4 px-4 py-4 transition sm:grid-cols-[minmax(0,1fr)_180px_110px_24px] sm:items-center ${
                    hasSpots ? "hover:bg-emerald-50" : "hover:bg-zinc-50"
                  }`}
                >
                  <div>
                    <div class="flex items-center gap-3">
                      <span
                        class={`h-2.5 w-2.5 rounded-full ${
                          hasSpots ? "bg-emerald-500" : "bg-amber-500"
                        }`}
                      />
                      <h3 class="font-medium text-zinc-950">{region.name}</h3>
                    </div>
                  </div>
                  <p class="text-sm text-zinc-500">
                    <span class="font-semibold text-zinc-950">
                      {regionPercent}%
                    </span>{" "}
                    zasedeno
                  </p>
                  <p class="text-sm text-zinc-500 sm:text-right">
                    <span class="font-semibold text-zinc-950">
                      {region.totals.totalApplications.freeSpots}
                    </span>{" "}
                    prosto
                  </p>
                  <span class="text-zinc-400 transition group-open:rotate-45">
                    +
                  </span>
                </summary>

                <div class="border-t border-zinc-100 px-4 pb-4">
                  <div class="overflow-x-auto">
                    <table class="w-full min-w-[760px] text-left text-sm">
                      <thead class="text-xs uppercase tracking-[0.12em] text-zinc-400">
                        <tr>
                          <th class="py-3 font-medium">Tip</th>
                          <th class="py-3 font-medium">Ime</th>
                          <th class="py-3 text-right font-medium">
                            Kapaciteta
                          </th>
                          <th class="py-3 text-right font-medium">Prosto</th>
                          <th class="py-3 text-right font-medium">
                            Aktivne prošnje
                          </th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-zinc-100">
                        {region.facilities.map((f) => (
                          <tr>
                            <td class="py-3">
                              <span class="rounded-full border border-zinc-200 px-2.5 py-1 text-xs text-zinc-500">
                                {f.type}
                              </span>
                            </td>
                            <td class="max-w-xs py-3 font-medium text-zinc-900">
                              {f.name}
                            </td>
                            <td class="py-3 text-right text-zinc-600">
                              {f.capacity}
                            </td>
                            <td class="py-3 text-right">
                              <span
                                class={`rounded-full px-2.5 py-1 text-xs font-semibold ${
                                  f.freeSpots && f.freeSpots > 0
                                    ? "bg-emerald-50 text-emerald-700"
                                    : "bg-zinc-100 text-zinc-500"
                                }`}
                              >
                                {f.freeSpots ?? "-"}
                              </span>
                            </td>
                            <td class="py-3 text-right text-zinc-600">
                              {typeof f.activeApplications === "number"
                                ? formatNumber(f.activeApplications)
                                : "-"}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </details>
            );
          })
        }
      </div>
    </section>

    {
      pricingData.length > 0 && (
        <section class="border-t border-zinc-200 bg-zinc-50">
          <div class="mx-auto max-w-7xl px-5 py-10 sm:px-8 lg:px-10">
            <div class="mb-6 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
              <div>
                <p class="text-sm font-medium uppercase tracking-[0.14em] text-zinc-500">
                  Stroški
                </p>
                <h2 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-950">
                  Primerjava cen
                </h2>
              </div>
              <p class="max-w-md text-sm leading-6 text-zinc-500">
                Mesečna cena je izračunana na podlagi 30,417 dni.
              </p>
            </div>

            <div class="overflow-hidden rounded-lg border border-zinc-200 bg-white">
              <div class="overflow-x-auto">
                <table class="w-full min-w-[900px] text-left text-sm">
                  <thead class="border-b border-zinc-200 text-xs uppercase tracking-[0.12em] text-zinc-500">
                    <tr>
                      <th class="px-4 py-3 font-medium">Dom</th>
                      {Array.from({ length: maxRooms }).map((_, i) => (
                        <th class="px-4 py-3 text-center font-medium">
                          {i === 0
                            ? "Najcenejša"
                            : i === maxRooms - 1
                              ? "Najdražja"
                              : `${i + 1}. opcija`}
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-zinc-100">
                    {pricingData.map((facility) => (
                      <tr class="transition hover:bg-zinc-50">
                        <td class="px-4 py-4">
                          <div class="font-semibold text-zinc-950">
                            {facility.name}
                          </div>
                          <div class="mt-1 text-xs text-zinc-500">
                            {facility.address.city}
                          </div>
                        </td>
                        {Array.from({ length: maxRooms }).map((_, i) => {
                          const room = facility.room_pricing[i];
                          return (
                            <td class="px-4 py-4 text-center">
                              {room ? (
                                <div title={room.room_type}>
                                  <div class="font-semibold text-zinc-950">
                                    {formatCurrency(room.monthly_rate)}
                                  </div>
                                  <div class="mt-1 text-xs text-zinc-500">
                                    {formatCurrency(room.daily_rate)}/dan
                                  </div>
                                </div>
                              ) : (
                                <span class="text-zinc-300">-</span>
                              )}
                            </td>
                          );
                        })}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </section>
      )
    }

    <footer class="border-t border-zinc-200 bg-white">
      <div
        class="mx-auto flex max-w-7xl flex-col gap-3 px-5 py-8 text-sm text-zinc-500 sm:px-8 lg:px-10"
      >
        <p>Podatki se samodejno posodabljajo dnevno.</p>
        <p>
          Vir: <a
            href={data._metadata.source}
            class="font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4 hover:decoration-zinc-950"
            target="_blank"
            rel="noopener">{data._metadata.source}</a
          >
        </p>
        <p class="text-xs">
          Zadnja posodobitev: {
            new Date(data._metadata.extractedAt).toLocaleString("sl-SI")
          }
        </p>
      </div>
    </footer>
  </main>
</Layout>
